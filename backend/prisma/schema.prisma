generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  tetrisScores  ScoreTetris[]
  wolfpackScores ScoreWolfpack[]
}

model ScoreTetris {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int
  lines     Int
  createdAt DateTime @default(now())
}

model ScoreWolfpack {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int
  waves     Int
  createdAt DateTime @default(now())
}

model SignupJob {
  id        String   @id @default(cuid())
  email     String
  status    String   @default("pending")
  userId    String?
  error     String?
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
